# Password mode A (simple):
SETUP_PASSWORD=CHANGE_ME_LONG_AND_RANDOM

# Password mode B (recommended hash):
# SETUP_PASSWORD_SALT=HEX_SALT_FROM_SCRIPT
# SETUP_PASSWORD_HASH=HEX_HASH_FROM_SCRIPT

# Secrets shown after successful login
DROPBOX_EMAIL=online@scito.org
DROPBOX_PASS=CHANGE_ME
ADMIN_PASS=CHANGE_ME

# JWT signing key (at least 32 random chars)
JWT_SECRET=CHANGE_ME_SUPER_SECRET_32_CHARS_MIN

# Session validity in days
SESSION_DAYS=7

# Login protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MS=60000
ATTEMPT_TTL_MS=900000

# Optional: restrict browser origin (e.g. https://yourdomain.com)
# APP_ORIGIN=

# Server port
PORT=3000